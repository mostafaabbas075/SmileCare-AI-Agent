# =============================================================================
# AI Dental Clinic Receptionist — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the real values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development                      # development | staging | production
APP_NAME="AI Dental Clinic Receptionist"
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR | CRITICAL

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Security (JWT — fill in before deploying)
# -----------------------------------------------------------------------------
SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dental_receptionist
POSTGRES_USER=dental_user
POSTGRES_PASSWORD=CHANGE_ME

# Constructed by the app from the fields above — no need to set manually.
# DATABASE_URL=postgresql+asyncpg://dental_user:CHANGE_ME@localhost:5432/dental_receptionist

# -----------------------------------------------------------------------------
# Qdrant (Vector Store)
# -----------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=dental_knowledge

# -----------------------------------------------------------------------------
# Google Gemini (LLM Provider)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=CHANGE_ME
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Sentence Transformers (Embeddings)
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
